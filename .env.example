# Immich Photo Sync configuration
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# Base URL of your Immich instance (no trailing slash)
IMMICH_BASE_URL=https://your-immich-instance.com

# API key for the first Immich account
API_KEY_1=your-first-account-api-key

# API key for the second Immich account
API_KEY_2=your-second-account-api-key

# Date range to sync (YYYY-MM-DD)
SYNC_START_DATE=2025-08-09
SYNC_END_DATE=2025-08-20

# Time between sync cycles, in seconds (default: 3600 = 1 hour)
SYNC_INTERVAL=3600

# SQLite database file for tracking sync state (optional, default: immich_sync.db)
DB_FILE=immich_sync.db

# --- Streaming / memory tuning (all optional) ---
# Assets are streamed directly from one account to the other, so even large
# videos are never fully loaded into RAM. These only need changing in unusual
# setups.
#
# Chunk size (bytes) used when a download has to be buffered because the server
# didn't send a Content-Length (default: 1 MiB).
STREAM_CHUNK_SIZE=1048576
# In that buffering fallback, keep up to this many bytes in RAM before spilling
# to a temporary file on disk (default: 8 MiB).
STREAM_SPOOL_MAX_BYTES=8388608
# Directory for those temporary spill files (default: system temp dir).
# STREAM_TEMP_DIR=/var/tmp
