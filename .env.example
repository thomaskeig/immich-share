# Immich Photo Sync configuration
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# Base URL of your Immich instance (no trailing slash)
IMMICH_BASE_URL=https://your-immich-instance.com

# API key for the first Immich account
API_KEY_1=your-first-account-api-key

# API key for the second Immich account
API_KEY_2=your-second-account-api-key

# Date range to sync (YYYY-MM-DD)
SYNC_START_DATE=2025-08-09
SYNC_END_DATE=2025-08-20

# Time between sync cycles, in seconds (default: 3600 = 1 hour)
SYNC_INTERVAL=3600

# SQLite database file for tracking sync state (optional, default: immich_sync.db)
DB_FILE=immich_sync.db
